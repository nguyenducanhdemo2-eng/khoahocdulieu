-- Truy Vấn
SELECT 
	   o.order_id AS "MÃ ĐƠN HÀNG",
       c.customer_name AS "TÊN KHÁCH HÀNG",
	   e.employee_name AS "TÊN NHÂN VIÊN",
	   o.order_date AS "NGÀY MUA",
	   sum(oi.quantity * oi.price_at_purchase) AS "TỔNG TIỀN"
	   From orders o
	   Join customers c on o.customer_id = c.customer_id
	   Join employees e on o.employee_id = e.employee_id
	   Join order_items oi on o.order_id = oi.order_id
group by o.order_id,
	c.customer_name,
	e.employee_name,
	o.order_date
order by "TỔNG TIỀN" DESC
limit 10;
       
SELECT pc.category_name AS "TÊN DANH MỤC",
	   SUM(oi.quantity * oi.price_at_purchase) AS " TỔNG DOANH THU"
FROM product_categories pc
join products p on pc.category_id = p.product_id
join order_items oi on p.product_id = oi.product_id
GROUP BY pc.category_name
HAVING SUM ( oi.quantity * oi.price_at_purchase) > 1000000
ORDER BY " TỔNG DOANH THU" DESC;

SELECT product_name AS "TÊN SẢN PHẨM",price AS " GIÁ BÁN " 
FROM products
where supplier_id =(
	select supplier_id
	FROM suppliers
	where supplier_name = 'TechVN'
); 

SELECT e.employee_id,	
	e.employee_name AS " TÊN NHÂN VIÊN ",
	sum(oi.quantity * oi.price_at_purchase) AS " TỔNG DOANH THU ",
	DENSE_RANK() OVER (ORDER BY SUM(oi.quantity * oi.price_at_purchase) DESC) AS "THỨ HẠNG"
	from employees e
	join orders o ON e.employee_id = o.employee_id
	join order_items oi On o.order_id = oi.order_id
	where o.order_date <= '2023-10-31' AND o.order_date >= '2023-10-31'
	group by e.employee_id,e.employee_name
	ORDER BY "THỨ HẠNG" ASC;


