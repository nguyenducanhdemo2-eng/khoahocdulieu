
DROP TABLE IF EXISTS product_categories CASCADE;
CREATE TABLE product_categories(
	category_id SERIAL PRIMARY KEY,
	category_name VARCHAR(225) NOT NULL UNIQUE
);

DROP TABLE IF EXISTS suppliers CASCADE;
CREATE TABLE suppliers( 
	supplier_id SERIAL PRIMARY KEY,
	supplier_name VARCHAR(225) NOT NULL,
	contact_inf VARCHAR(225)
);

DROP TABLE IF EXISTS promotions CASCADE;
CREATE TABLE promotions ( 
	promo_id SERIAL PRIMARY KEY,
	promo_name VARCHAR(225) NOT NULL,
	MO_TA TEXT,
	discount_percent DECIMAL(5,2),
	start_date DATE NOT NULL,
	end_date DATE NOT NULL
);

DROP TABLE IF EXISTS employees CASCADE;
CREATE TABLE employees (
	employee_id SERIAL PRIMARY KEY,
	employee_name VARCHAR(225) NOT NULL,
	Vi_Tri_CV VARCHAR(225) NOT NULL,
	hire_date DATE
);

DROP TABLE IF EXISTS customers CASCADE;
CREATE TABLE customers(
	customer_id SERIAL PRIMARY KEY,
	customer_name VARCHAR(225) NOT NULL,
	phone VARCHAR(20) UNIQUE,
	email VARCHAR(225) UNIQUE,
	address TEXT
);

DROP TABLE IF EXISTS products CASCADE;
CREATE TABLE products (
	product_id SERIAL PRIMARY KEY,
	product_name VARCHAR(250) NOT NULL,
	price DECIMAL(15,2) NOT NULL,
	category_id INT REFERENCES product_categories(category_id) ON DELETE SET NULL, -- Bổ sung Khóa ngoại
	supplier_id INT REFERENCES suppliers(supplier_id) ON DELETE SET NULL        -- Bổ sung Khóa ngoại
);

DROP TABLE IF EXISTS orders CASCADE;
CREATE TABLE orders(
	order_id SERIAL PRIMARY KEY,
	customer_id INT NOT NULL REFERENCES customers(customer_id) ON DELETE CASCADE,   -- Bổ sung Khóa ngoại
	employee_id INT NOT NULL REFERENCES employees(employee_id) ON DELETE RESTRICT,  -- Bổ sung Khóa ngoại
	promo_id INT REFERENCES promotions(promo_id) ON DELETE SET NULL,                -- Bổ sung Khóa ngoại
	order_date DATE DEFAULT CURRENT_DATE
);

DROP TABLE IF EXISTS order_items CASCADE;
CREATE TABLE order_items (
	order_item_id SERIAL PRIMARY KEY,
	order_id INT NOT NULL REFERENCES orders(order_id) ON DELETE CASCADE,       -- Bổ sung Khóa ngoại
	product_id INT NOT NULL REFERENCES products(product_id) ON DELETE RESTRICT,-- Bổ sung Khóa ngoại
	quantity INT NOT NULL CHECK (quantity > 0),
	price_at_purchase DECIMAL(15,2) NOT NULL CHECK(price_at_purchase >= 0)
);

